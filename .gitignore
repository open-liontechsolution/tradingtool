# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
/env/

# Testing
.pytest_cache/
.coverage
htmlcov/
/tmp/test_results*.txt
/tmp/build*.txt

# Local research scratch (strategy sweeps, NDJSON, scratch scripts).
# All artifacts under this folder are regenerable and stay local.
/tmp/strategy_research/

# Database / data files
data/*.db
data/*.db-wal
data/*.db-shm

# Environment
.env
.env.*

# Node / frontend
frontend/node_modules/
frontend/dist/

# IDE / OS
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Windsurf plans (local session artifacts)
.windsurf/

# Ruff cache
.ruff_cache/

# Alembic generated (keep versions/ tracked, ignore auto-generated cache)
alembic/__pycache__/

# helm — secret manifests live outside the repo, organised per env
# under helm/secrets/. The example template is committed; the real
# manifests (helm/secrets/<env>.yaml) are not.
helm/secrets/*.yaml
!helm/secrets/example.yaml
# Legacy locations from before the helm/secrets/ reorg — kept ignored
# so old local checkouts don't accidentally commit them.
helm/env/secrets.yaml
helm/env/secrets-*.yaml

# Loose credential drop-files at repo root (keys.txt, cloudflare, etc).
# Never commit these — even temporarily — because `git add -A` will pick
# them up. If you need to share creds during a session, use
# helm/secrets/<env>.yaml or out-of-band channels.
/keys.txt
/cloudflare
/secrets.txt
/credentials.txt
/.env*

# Claude — only commit project-scoped skills, never per-user settings.
.claude/*
!.claude/skills/
!.claude/skills/**
.mcp.json

# QA walkthrough screenshots — heavy, regenerable, kept local.
# The markdown reports themselves ARE committed for historical record.
qa-walkthrough-reports/screenshots/

# Playwright CLI local session artifacts
.playwright/
.playwright-cli/
